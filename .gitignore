# ============================================
# .gitignore - Docker & Build Artifacts
# ============================================

# Docker
.docker/
*.pid
*.seed
*.log

# Build outputs
dist/
build/
.next/
out/

# Dependencies
node_modules/
jspm_packages/

# Environment
.env
.env*.local
.env.production

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Testing
coverage/
.nyc_output/
playwright-report/
test-results/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# OS
Thumbs.db
Desktop.ini

# Temporary
tmp/
temp/
.cache/

# Database
*.db
*.sqlite
*.sqlite3

# SSL Certificates (production)
nginx/ssl/*.pem
nginx/ssl/*.key

# Uploads (user generated content)
public/uploads/*
!public/uploads/.gitkeep

# Backups
*.bak
*.backup
backup.sql
